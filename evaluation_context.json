{
  "project_structure": [
    "babel.config.js",
    ".gitignore",
    "app.json",
    "evaluation_context.json",
    "expo-env.d.ts",
    "tsconfig.json",
    "package.json",
    "README.txt",
    "package-lock.json",
    "eas.json",
    "components/InfoRow.tsx",
    "components/AccessoryRow.tsx",
    "components/HomeSection.tsx",
    "modules/expo-homekit/package.json",
    "modules/expo-homekit/ExpoHomeKit.podspec",
    "modules/expo-homekit/index.ts",
    "modules/expo-homekit/app.plugin.js",
    "modules/expo-homekit/expo-module.config.json",
    "modules/expo-homekit/src/ExpoHomeKitModule.ts",
    "modules/expo-homekit/src/ExpoHomeKit.types.ts",
    "assets/icon.png",
    "assets/images/splash-icon.png",
    "lib/homekit.ts",
    "lib/wifi.ts",
    "app/_layout.tsx",
    "app/(tabs)/_layout.tsx",
    "app/(tabs)/wifi.tsx",
    "app/(tabs)/index.tsx"
  ],
  "config_files": {
    "app.json": {
      "expo": {
        "name": "test-app-3",
        "slug": "test-app-3",
        "version": "0.1.0",
        "scheme": "testapp3",
        "orientation": "portrait",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
          "supportsTablet": true,
          "bundleIdentifier": "app.tminus.test-app-3",
          "entitlements": {
            "com.apple.developer.networking.wifi-info": true
          },
          "infoPlist": {
            "NSLocationWhenInUseUsageDescription": "Location access is required by iOS to read the current WiFi SSID.",
            "ITSAppUsesNonExemptEncryption": false
          },
          "config": {
            "usesNonExemptEncryption": false
          }
        },
        "plugins": [
          "expo-router",
          "./modules/expo-homekit/app.plugin.js"
        ],
        "experiments": {
          "typedRoutes": true
        },
        "web": {
          "bundler": "metro",
          "favicon": null
        },
        "icon": "./assets/icon.png",
        "owner": "robert_castagna",
        "extra": {
          "router": {},
          "eas": {
            "projectId": "dbc6d8ec-b58c-47fe-8b3e-2f3fa5684fe5"
          }
        },
        "splash": {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      }
    },
    "package.json": {
      "name": "test-app-3",
      "version": "0.1.0",
      "main": "expo-router/entry",
      "scripts": {
        "start": "expo start",
        "ios": "expo run:ios",
        "prebuild": "expo prebuild --clean",
        "typecheck": "tsc --noEmit",
        "android": "expo run:android"
      },
      "dependencies": {
        "@react-native-community/netinfo": "~11.4.0",
        "babel-preset-expo": "~54.0.10",
        "expo": "~54.0.0",
        "expo-constants": "~18.0.0",
        "expo-linking": "~8.0.0",
        "expo-router": "~6.0.0",
        "expo-status-bar": "~3.0.0",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.16.0",
        "react-native-web": "^0.21.0"
      },
      "devDependencies": {
        "@types/react": "~19.1.0",
        "typescript": "~5.9.0"
      },
      "private": true
    },
    "eas.json": {
      "cli": {
        "version": ">= 12.0.0",
        "appVersionSource": "remote"
      },
      "build": {
        "development": {
          "developmentClient": true,
          "distribution": "internal",
          "ios": {
            "simulator": false
          },
          "credentialsSource": "local"
        },
        "preview": {
          "distribution": "internal",
          "credentialsSource": "local"
        },
        "production": {
          "autoIncrement": true,
          "credentialsSource": "local"
        }
      },
      "submit": {
        "production": {}
      }
    }
  },
  "dependencies": {
    "@react-native-community/netinfo": "~11.4.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-linking": "~8.0.0",
    "expo-router": "~6.0.0",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "navigation_structure": "Not fully analyzed in this version",
  "permissions": [
    {
      "ios_infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location access is required by iOS to read the current WiFi SSID.",
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  ],
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.0"
  }
}