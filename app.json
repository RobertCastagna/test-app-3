{
  "expo": {
    "name": "test-app-3",
    "slug": "test-app-3",
    "version": "0.1.0",
    "scheme": "testapp3",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tminus.test-app-3",
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location access is required by iOS to read the current WiFi SSID.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "./modules/expo-homekit/app.plugin.js"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "favicon": null
    },
    "icon": "./assets/icon.png",
    "owner": "robert_castagna",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dbc6d8ec-b58c-47fe-8b3e-2f3fa5684fe5"
      }
    },
    "splash": {
      "image": null,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}
